<?xml version="1.0" encoding="utf-8"?>
<layer-list
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/top_banner_video_more_radius" />
            <solid android:color="@color/top_banner_video_more_background_color" />
        </shape>
    </item>
    <item>
        <ripple android:color="@color/top_banner_video_mute_ripple_color">
            <item android:id="@android:id/mask">
                <shape android:shape="rectangle">
                    <solid android:color="@android:color/white" />
                    <corners android:radius="@dimen/top_banner_video_more_radius" />
                </shape>
            </item>
        </ripple>
    </item>
</layer-list>