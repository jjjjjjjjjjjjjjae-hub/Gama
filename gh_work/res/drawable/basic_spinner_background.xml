<?xml version="1.0" encoding="utf-8"?>
<layer-list
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <ripple android:color="@color/basic_light_theme_ripple_color">
            <item android:id="@android:id/mask">
                <shape android:shape="rectangle">
                    <solid android:color="?android:colorBackground" />
                    <corners android:radius="@dimen/basic_ripple_radius" />
                </shape>
            </item>
        </ripple>
    </item>
    <item android:gravity="end|center" android:height="@dimen/basic_spinner_triangle_height" android:width="@dimen/basic_spinner_triangle_width" android:end="@dimen/basic_spinner_triangle_end">
        <bitmap android:src="@drawable/tw_spinner_mtrl_am_alpha" android:tint="@color/playhistory_spinner_triangle" />
    </item>
</layer-list>