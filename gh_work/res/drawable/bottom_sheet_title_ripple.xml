    </item>
    <item android:id="@android:id/background">
        <shape android:shape="rectangle">
            <corners android:topLeftRadius="@dimen/main_my_games_layout_radius" android:topRightRadius="@dimen/main_my_games_layout_radius" />
            <solid android:color="@color/transparent" />
        </shape>
    </item>
